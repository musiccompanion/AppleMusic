{
    "name": "music-companion/apple-music",
    "type": "library",
    "description": "Apple Music SDK",
    "keywords": ["apple", "music", "sdk"],
    "homepage": "http://github.com/MusicCompanion/AppleMusic",
    "license": "MIT",
    "authors": [
        {
            "name": "Baptiste Langlade",
            "email": "baptiste.langlade@hey.com"
        }
    ],
    "support": {
        "issues": "http://github.com/MusicCompanion/AppleMusic/issues"
    },
    "require": {
        "php": "~8.4",
        "innmind/foundation": "~2.1",
        "innmind/colour": "~5.0",
        "lcobucci/jwt": "~4.3|~5.0"
    },
    "autoload": {
        "psr-4": {
            "MusicCompanion\\AppleMusic\\": "src/",
            "Fixtures\\MusicCompanion\\AppleMusic\\": "fixtures/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\MusicCompanion\\AppleMusic\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "~12.0",
        "innmind/black-box": "~6.5",
        "innmind/static-analysis": "~1.3",
        "innmind/coding-standard": "~2.0"
    }
}
